# Supabase — find these in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Postmark — a secret token you choose; send it in the webhook header X-Postmark-Secret
POSTMARK_WEBHOOK_SECRET=your-random-secret-here

# Allowed login emails
ALLOWED_EMAIL_PARENT=parent@example.com
ALLOWED_EMAIL_STUDENT=milene@example.com
